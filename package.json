{
  "name": "@jscarle/vue3-turnstile",
  "version": "1.0.3",
  "description": "A Vue 3.5 TypeScript component for Cloudflare's Turnstile.",
  "private": false,
  "main": "./dist/vue3-turnstile.umd.js",
  "module": "./dist/vue3-turnstile.es.js",
  "types": "./dist/types/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "require": "./dist/vue3-turnstile.umd.js",
      "import": "./dist/vue3-turnstile.es.js"
    }
  },
  "sideEffects": false,
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jscarle/vue3-turnstile"
  },
  "bugs": {
    "url": "https://github.com/jscarle/vue3-turnstile/issues"
  },
  "homepage": "https://github.com/jscarle/vue3-turnstile#readme",
  "keywords": [
    "vue",
    "turnstile",
    "cloudflare",
    "captcha"
  ],
  "scripts": {
    "build": "npm run clean && npm run type && vite build",
    "clean": "rimraf dist",
    "type": "vue-tsc -p tsconfig.app.json",
    "lint": "eslint . --fix",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@unhead/vue": "^2.0.12",
    "vue": "^3.5.17"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.2",
    "@types/node": "^24.1.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vitest/eslint-plugin": "^1.3.4",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.7.0",
    "eslint": "^9.32.0",
    "eslint-plugin-vue": "~10.4.0",
    "jiti": "^2.5.1",
    "jsdom": "^26.1.0",
    "rimraf": "^6.0.1",
    "typescript": "~5.8.3",
    "vite": "^7.0.6",
    "vitest": "^3.2.4",
    "vue-tsc": "^3.0.5"
  },
  "publishConfig": {
    "access": "public"
  }
}
