{
  "name": "@jscarle/vue3-turnstile",
  "version": "1.0.0",
  "private": false,
  "main": "./dist/vue3-turnstile.umd.js",
  "module": "./dist/vue3-turnstile.es.js",
  "types": "./dist/types/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "require": "./dist/vue3-turnstile.umd.js",
      "import": "./dist/vue3-turnstile.es.js",
      "types": "./dist/types/index.d.ts"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run clean && npm run type && vite build",
    "clean": "rimraf dist",
    "preview": "vite preview",
    "type": "vue-tsc -p tsconfig.app.json",
    "lint": "eslint . --fix",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@unhead/vue": "^2.0.12",
    "vue": "^3.5.17"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.2",
    "@types/cloudflare-turnstile": "^0.2.2",
    "@types/node": "^22.15.32",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vue/tsconfig": "^0.7.0",
    "eslint": "^9.29.0",
    "eslint-plugin-vue": "~10.2.0",
    "typescript": "~5.8.0",
    "vite": "^7.0.0",
    "vue-tsc": "^2.2.10",
    "vitest": "^1.5.0",
    "@vue/test-utils": "^2.4.1",
    "rimraf": "^5.0.0",
    "jsdom": "^24.0.0"
  }
}
