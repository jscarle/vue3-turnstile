{
  "name": "@jscarle/vue3-turnstile",
  "version": "1.1.0",
  "description": "A Vue 3.5 TypeScript component for Cloudflare's Turnstile.",
  "private": false,
  "main": "./dist/vue3-turnstile.umd.js",
  "module": "./dist/vue3-turnstile.es.js",
  "types": "./dist/types/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "require": "./dist/vue3-turnstile.umd.js",
      "import": "./dist/vue3-turnstile.es.js"
    }
  },
  "sideEffects": false,
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jscarle/vue3-turnstile.git"
  },
  "bugs": {
    "url": "https://github.com/jscarle/vue3-turnstile/issues"
  },
  "homepage": "https://github.com/jscarle/vue3-turnstile#readme",
  "keywords": [
    "vue",
    "turnstile",
    "cloudflare",
    "captcha"
  ],
  "scripts": {
    "build": "npm run clean && npm run type && vite build",
    "clean": "rimraf dist",
    "type": "vue-tsc -p tsconfig.app.json",
    "lint": "eslint . --fix",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@unhead/vue": "^2.0.12 || ^3.1.0",
    "vue": "^3.5.17"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.5",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/eslint-plugin": "^1.6.16",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.9",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.2.1",
    "eslint-plugin-vue": "^10.9.0",
    "jiti": "^2.6.1",
    "jsdom": "^29.1.0",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.7"
  },
  "overrides": {
    "glob": "^13.0.6"
  },
  "publishConfig": {
    "access": "public"
  }
}
